#!/usr/bin/env bash


# initialize new file for automatic wrapper procedures -------------------------
#
# arguments:
#     1    name for output file
#     2    path or prefix for source file(s)
#
function open_autowrap() {
    output=$1
    path=$2
    cat > $output << EOF
! This file is generated automatically. DO NOT EDIT.
EOF
}
# open_autowrap ----------------------------------------------------------------



# generate f2py wrapper procedure ----------------------------------------------
#
# arguments:
#     1    procedure type (subroutine or function)
#     2    procedure name
#     3    file name (relative to $path), if applicable
#     4    prefix for name of wrapped procedure
#
function autowrap() {
    proctype=$1
    basename=$2
    src=${path}/$3
    procname=$4${basename}
    if [[ "$path" == *f90 ]]; then
        src=$path
    fi


    # use module statement
    flare_module=$(gawk '/^module/ { print $2 }' ${src})
    if [ "$flare_module" == "" ]; then
        wrapped_proc=${procname}
        use_flare_module=""
    else
        wrapped_proc="wrapped_proc"
        use_flare_module="  use ${flare_module}, only: ${wrapped_proc} => ${procname}"
    fi


    # execute statement & signature
    signature=$(sed -n "/${proctype} ${procname}(/,\${p;/)/q;}" $src)
    args=$(echo "${signature}" | cut -d "(" -f 2 | cut -d ")" -f 1)
    case "$proctype" in
    subroutine)
        run="call ${wrapped_proc}(${args})"
        result=
        specs_add=
        ;;

    function)
        variable=$(echo ${signature} | cut -d "(" -f 3 | cut -d ")" -f 1)
        result=" result(${variable})"
        if [ "${variable}" == "" ]; then
            result=
            variable=${procname}
        fi
        run="${variable} = ${wrapped_proc}(${args})"
        specs_add="\|:: ${variable}"
        ;;

    esac
    specs=$(sed -n "/${proctype} ${procname}(/,/end ${proctype} ${procname}/p" $src | sed "/contains/,\$d" | grep "intent(${specs_add}")


    # output
    cat >> $output << EOF


  !-----------------------------------------------------------------------------
  ${proctype} ${basename}(${args})${result}
${use_flare_module}
${specs}

  ${run}

  end ${proctype} ${basename}
  !-----------------------------------------------------------------------------
EOF

}
# autowrap ---------------------------------------------------------------------



# ------------------------------------------------------------------------------
function autowrap_sub() {
    autowrap "subroutine" $@
}

function autowrap_func() {
    autowrap "function" $@
}
# ------------------------------------------------------------------------------





# main program starts here =====================================================


basename=$(basename $1)
fortran_source_dir=$2
case "$basename" in
_tasks.f90)
    open_autowrap   $1   ${fortran_source_dir}/tasks.f90
    autowrap_sub    connection_length
    autowrap_sub    strike_point_density
    autowrap_sub    heat_load_proxy
    ;;


_geometry.f90)
    open_autowrap   $1   ${fortran_source_dir}/geometry.f90
    autowrap_sub    init_workspace
    autowrap_sub    set_pfc
    ;;
esac
