# Data folder — ignore contents but keep the folder structure via .gitkeep
Data/*
!Data/.gitkeep

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/

# Large binaries / data files
*.nc
*.h5
*.hdf5

# Editor / OS
.vscode/
.DS_Store
*:Zone.Identifier

# Local reference copies of third-party source (installed separately from
# ~/Academia/Software; kept here only for easy reading, not version-controlled)
Code/Source_Codes/

# Build / packaging / lofted-surface outputs
*.egg-info/
build/
dist/
*.torosurf
*.stl
